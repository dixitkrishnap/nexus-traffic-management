# ─── NEXUS Backend — Environment Variables ───────────────
# Copy to .env and fill in your values

# App
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database (SQLite for dev; swap to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./nexus.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nexus

# ─── Anthropic LLM ────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=1024

# ─── IoT / Sensor Simulation ──────────────────────────────
# In production: replace with real MQTT broker
SENSOR_POLL_INTERVAL_S=5
IOT_SIMULATE=true
# MQTT_HOST=localhost
# MQTT_PORT=1883
# MQTT_TOPIC_PREFIX=nexus/sensors/

# ─── Traffic Engine ───────────────────────────────────────
CONGESTION_WARN_THRESHOLD=0.55
CONGESTION_CRIT_THRESHOLD=0.75
SIGNAL_MIN_GREEN_S=15
SIGNAL_MAX_GREEN_S=90
SIGNAL_YELLOW_S=4

# ─── Alert System ─────────────────────────────────────────
ALERT_RETENTION_HOURS=24

# ─── Emergency ────────────────────────────────────────────
EMERGENCY_CORRIDOR_TIMEOUT_S=300

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:5500","*"]
